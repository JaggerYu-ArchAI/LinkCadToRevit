  "Nodes": [
    {
      "ConcreteType": "DSRevitNodesUI.Levels, DSRevitNodesUI",
      "SelectedIndex": 0,
      "SelectedString": "标高 1",
      "Id": "5d239355b59d4f02a21511e06b301e2a",
      "NodeType": "ExtensionNode",
      "Inputs": [],
