    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "# -*- coding: utf-8 -*-\r\n# 固定导入内容\r\n# 1. 加载Python Standard和DesignScript库\r\nimport sys\r\nimport os\r\nimport math\r\nimport json\r\nimport clr\r\n\r\nclr.AddReference('ProtoGeometry')  # Dynamo核心几何库\r\nfrom Autodesk.DesignScript.Geometry import *\r\nimport Autodesk.DesignScript.Geometry as DynGeometry # 为避免冲突，使用DynGeometry.XX\r\n\r\nclr.AddReference('DSCoreNodes')  # Dynamo核心基础库\r\nimport DSCore  # 为避免冲突，使用DSCore.List.XX\r\n\r\nclr.AddReference('RevitNodes')  # Dynamo Revit专属节点库\r\nimport Revit   # 为避免冲突，使用Revit.Elements.XX\r\nclr.ImportExtensions(Revit.Elements)\r\nclr.ImportExtensions(Revit.GeometryConversion)\r\n\r\n# 2. 导入Revit API\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitAPIUI')\r\nclr.AddReference(\"System.Collections\")\r\nimport System\r\nfrom Autodesk.Revit.DB import *\r\nfrom Autodesk.Revit.UI import *\r\nfrom System.Collections.Generic import *\r\n\r\n# 3. 导入Revit管理服务\r\nclr.AddReference(\"RevitServices\")\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\n# 4. 全局文档对象\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\napp = doc.Application\r\nuiApp = DocumentManager.Instance.CurrentUIApplication\r\nuidoc = uiApp.ActiveUIDocument\r\n\r\n# 该节点的输入内容将存储为 IN 变量中的一个列表。\r\ndataEnteringNode = IN\r\n\r\ncolumn_curves = DSCore.List.Flatten(IN[0])\r\norigin_points = DSCore.List.Flatten(IN[1])\r\ntext_value = DSCore.List.Flatten(IN[2])\r\nlevel = IN[3]\r\nfamily_name = IN[4]\r\n\r\n# ==================================================\r\n# 成组相连的曲线\r\n# ==================================================\r\ndef _group_curves(curves_list):\r\n    \"\"\"\r\n    成组相连的线条，可用于多段线\r\n    \"\"\"\r\n    curves = list(DSCore.List.Flatten(curves_list))\r\n    ignore_distance = 0.1\r\n    grouped_lines = []\r\n\r\n    while curves:\r\n        Shape = []\r\n        Queue = [curves.pop()]\r\n        while Queue:\r\n            current_line = Queue.pop(0)\r\n            Shape.append(current_line)\r\n            # 临时存储要加入的曲线，避免循环内重复判断\r\n            add_list = []\r\n            for potential_match in curves:\r\n                p1s = (potential_match.StartPoint, potential_match.EndPoint)\r\n                p2s = (current_line.StartPoint, current_line.EndPoint)\r\n                for p1 in p1s:\r\n                    for p2 in p2s:\r\n                        if p1.DistanceTo(p2) <= ignore_distance:\r\n                            if potential_match not in add_list:\r\n                                add_list.append(potential_match)\r\n                            break\r\n                    else:\r\n                        continue\r\n                    break\r\n            # 批量加入队列\r\n            for crv in add_list:\r\n                if crv not in Queue:\r\n                    Queue.append(crv)\r\n            # 剔除已入队曲线\r\n            curves = [c for c in curves if c not in Queue]\r\n        grouped_lines.append(Shape)\r\n    return grouped_lines\r\n\r\ngroup_curves = _group_curves(column_curves)\r\npoly_curves = [PolyCurve.ByJoinedCurves(curve) for curve in group_curves]\r\n\r\n\r\n# ==================================================\r\n# 根据文本，获取对应的族类型\r\n# ==================================================\r\npoly_curves_p = [p_curve.Points for p_curve in poly_curves]\r\npolygon = [Polygon.ByPoints(row) for row in poly_curves_p]\r\nmid_points = [Polygon.Center(poly) for poly in polygon]\r\n\r\ntext_distance = [[p.DistanceTo(op) for op in origin_points] for p in mid_points]\r\nsorted_text_distance  = [DSCore.List.Sort(row) for row in text_distance]\r\nshortest_dis = [dis[0] for dis in sorted_text_distance]\r\n\r\nshortest_index = []\r\nfor i in range(len(mid_points)):\r\n    idx = DSCore.List.FirstIndexOf(text_distance[i], shortest_dis[i])\r\n    shortest_index.append(idx)\r\n\r\nfilter_text_value = [DSCore.List.GetItemAtIndex(text_value, index) for index in shortest_index]\r\npoints = mid_points\r\n\r\ncolumn_points = []\r\ncolumn_type = []\r\nfor i in range(len(mid_points)):\r\n    # 规避报错导致停止\r\n    try:\r\n        type = Revit.Elements.FamilyType.ByFamilyNameAndTypeName(family_name, filter_text_value[i])\r\n        point = points[i]\r\n    except:\r\n        continue\r\n    column_type.append(type)\r\n    column_points.append(point)\r\n\r\n# OUT = column_points\r\n\r\ncolumns = []\r\nfor i in range(len(mid_points)):\r\n    column = Revit.Elements.FamilyInstance.ByPointAndLevel(column_type[i], column_points[i], level)\r\n    columns.append(column)\r\n\r\n\r\n# ==================================================\r\n# 检查柱子是否需要旋转\r\n# ==================================================\r\ncol_solids = DSCore.List.Flatten([col.Solids for col in columns], -1)\r\nintersect_all = [[Geometry.Intersect(poly, col) for col in col_solids] for poly in polygon]\r\n  \r\nintersect_lines_0 = [[row for row in rows if len(row)>1] for rows in intersect_all]\r\nintersect_lines = DSCore.List.Flatten(intersect_lines_0, 1)\r\ncurve_length = [[cur.Length for cur in row] for row in intersect_lines]\r\ncol_max_list = [DSCore.List.MaximumItem(row) for row in curve_length]\r\n\r\ngroup_length = [[cur.Length for cur in row] for row in group_curves]\r\ngroup_max_list = [DSCore.List.MaximumItem(row) for row in group_length]\r\n\r\nmask = []\r\nfor i in range(len(col_max_list)):\r\n    value = int(col_max_list[i]) == int(group_max_list[i])\r\n    mask.append(value)\r\n\r\ncolumns_unrotate = DSCore.List.FilterByBoolMask(columns, mask)[\"in\"]\r\ncolumns_for_rotate = DSCore.List.FilterByBoolMask(columns, mask)[\"out\"]\r\ncolumns_rotate = [Revit.Elements.FamilyInstance.SetRotation(col, 90) for col in columns_for_rotate]\r\nfinal_columns = DSCore.List.Flatten([columns_unrotate, columns_rotate])\r\n\r\nOUT = final_columns\r\n\r\n",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "ddf25de24d4f4a80a34bcd4e88592981",
